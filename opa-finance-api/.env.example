# Ambiente local de desenvolvimento
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/api_finance_dev

# Banco exclusivo para testes automatizados
DATABASE_URL_TEST=postgresql://USER:PASSWORD@localhost:5432/api_finance_test

JWT_SECRET=change-me
REFRESH_TOKEN_SECRET=change-me-too
LOG_LEVEL=info
CORS_ORIGINS=*
PORT=3333
HOST=0.0.0.0
RECURRENCES_JOB_ENABLED=true
RECURRENCES_JOB_TARGET_TIME=00:10
RECURRENCES_JOB_POLL_INTERVAL_MS=60000
RECURRENCES_JOB_LOCK_TTL_MS=900000
RECURRENCES_JOB_TIMEOUT_MS=600000
RECURRENCES_JOB_RETRY_DELAYS_MS=30000,120000,300000
RECURRENCES_JOB_BATCH_SIZE=500
RECURRENCES_JOB_MAX_ATTEMPTS=3
RECURRENCES_JOB_MAX_BATCHES_PER_USER_RUN=20

# Acesso SSH para scripts de manutencao e sync prod -> dev
SSH_HOST=user@server
SSH_KEY=~/.ssh/id_ed25519
SSH_CONTAINER_NAME=postgres_infra

# Bancos remotos
SSH_POSTGRES_USER=api_finance_api
SSH_POSTGRES_DB=api_finance
SSH_POSTGRES_DEV_DB=api_finance_dev
SSH_POSTGRES_TEST_DB=api_finance_test
